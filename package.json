{
  "name": "csharp-markdown-formatter",
  "displayName": "C# Markdown Code Block Formatter",
  "description": "Formats C# fenced code blocks in Markdown files. Place your cursor inside a ```csharp block and press Ctrl+Shift+Alt+F.",
  "version": "1.0.0",
  "publisher": "liquidfiend",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Formatters"],
  "keywords": ["csharp", "c#", "markdown", "formatter", "code block", "fenced"],
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/LiquidFiend/csharp-markdown-formatter"
  },
  "bugs": {
    "url": "https://github.com/LiquidFiend/csharp-markdown-formatter/issues"
  },
  "homepage": "https://github.com/LiquidFiend/csharp-markdown-formatter#readme",
  "activationEvents": ["onLanguage:markdown"],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "C# Markdown Formatter",
      "properties": {
        "csharpMarkdown.indentStyle": {
          "type": "string",
          "enum": ["tabs", "spaces"],
          "enumDescriptions": [
            "Indent with tab characters",
            "Indent with spaces"
          ],
          "default": "tabs",
          "description": "Indentation style used when formatting C# code blocks in Markdown."
        },
        "csharpMarkdown.indentSize": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 8,
          "description": "Number of spaces per indent level (only used when indentStyle is 'spaces')."
        }
      }
    },
    "commands": [
      {
        "command": "csharpMarkdown.formatBlock",
        "title": "Format C# Code Block"
      }
    ],
    "keybindings": [
      {
        "command": "csharpMarkdown.formatBlock",
        "key": "ctrl+shift+alt+f",
        "mac": "cmd+shift+alt+f",
        "when": "editorLangId == markdown"
      }
    ]
  }
}
